{%- comment -%}
  Zipfelmaus Energie — TRMNL full layout (800x480).
  Source of truth: docs/trmnl/full.liquid in the ziwoas repo.
  Update this file in the repo first, then paste into the TRMNL plugin UI.

  Receives merge_variables: ts, pv_kwh, cons_kwh, bilanz_kwh, autarky, self_use, ev[24], es[24]
{%- endcomment -%}

{%- assign max_h = 0 -%}
{%- for i in (0..23) -%}
  {%- assign total = ev[i] | plus: es[i] -%}
  {%- if total > max_h -%}{%- assign max_h = total -%}{%- endif -%}
{%- endfor -%}
{%- if max_h == 0 -%}{%- assign max_h = 1 -%}{%- endif -%}

<div style="display:flex;flex-direction:column;height:100%;padding:10px 18px 0;box-sizing:border-box">

  <div style="display:flex;justify-content:space-between;align-items:flex-start">
    <div>
      <span class="label">PV</span>
      <div style="display:flex;align-items:baseline;gap:8px;white-space:nowrap">
        <span class="value value--xlarge">{{ pv_kwh | replace: ".", "," }}</span>
        <span class="label">kWh</span>
      </div>
    </div>
    <div style="text-align:right">
      <span class="label">Bilanz</span>
      <div style="display:flex;align-items:baseline;gap:8px;white-space:nowrap;justify-content:flex-end">
        <span class="value value--xlarge">
          {%- if bilanz_kwh > 0 -%}+{%- endif -%}
          {{ bilanz_kwh | replace: ".", "," }}
        </span>
        <span class="label">kWh</span>
      </div>
    </div>
  </div>

  <div style="flex:1;min-height:0;display:flex;flex-direction:column;margin-top:6px">
    <svg viewBox="0 0 720 180" width="100%" preserveAspectRatio="none" style="width:100%;flex:1;min-height:0">
      <defs>
        <pattern id="hatch" patternUnits="userSpaceOnUse" width="3" height="3" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="3" stroke="black" stroke-width="1"/>
        </pattern>
      </defs>
      <line x1="0" y1="178" x2="720" y2="178" stroke="black" stroke-width="0.6"/>
      {%- for i in (0..23) -%}
        {%- assign x  = i | times: 30 -%}
        {%- assign ev_h = ev[i] | times: 168 | divided_by: max_h -%}
        {%- assign es_h = es[i] | times: 168 | divided_by: max_h -%}
        {%- assign ev_y = 178 | minus: ev_h -%}
        {%- assign es_y = ev_y | minus: es_h -%}
        {%- if ev_h > 0 -%}
          <rect x="{{ x | plus: 2 }}" y="{{ ev_y }}" width="26" height="{{ ev_h }}" fill="black"/>
        {%- else -%}
          <rect x="{{ x | plus: 2 }}" y="176" width="26" height="2" fill="black" fill-opacity="0.25"/>
        {%- endif -%}
        {%- if es_h > 0 -%}
          <rect x="{{ x | plus: 2 }}" y="{{ es_y }}" width="26" height="{{ es_h }}" fill="url(#hatch)" stroke="black" stroke-width="0.5"/>
        {%- endif -%}
      {%- endfor -%}
    </svg>
    <div style="display:flex;justify-content:space-between;padding:2px 0 0">
      <span class="label">−24 h</span>
      <span class="label">−18 h</span>
      <span class="label">−12 h</span>
      <span class="label">−6 h</span>
      <span class="label">jetzt</span>
    </div>
  </div>

  <div style="display:flex;justify-content:space-between;align-items:flex-start;padding:22px 0 6px">
    <div>
      <span class="label">Verbraucht</span>
      <div style="display:flex;align-items:baseline;gap:6px;white-space:nowrap">
        <span class="value value--medium">{{ cons_kwh | replace: ".", "," }}</span>
        <span class="label">kWh</span>
      </div>
    </div>
    <div style="text-align:center">
      <span class="label">Autarkie</span>
      <div style="display:flex;align-items:baseline;gap:6px;white-space:nowrap;justify-content:center">
        <span class="value value--medium">{{ autarky }}</span>
        <span class="label">%</span>
      </div>
    </div>
    <div style="text-align:right">
      <span class="label">Eigenverbrauch</span>
      <div style="display:flex;align-items:baseline;gap:6px;white-space:nowrap;justify-content:flex-end">
        <span class="value value--medium">{{ self_use }}</span>
        <span class="label">%</span>
      </div>
    </div>
  </div>
</div>

<div class="title_bar">
  <span class="title">Zipfelmaus Energie</span>
  <span class="instance">Stand {{ ts | date: "%H:%M" }}</span>
</div>
