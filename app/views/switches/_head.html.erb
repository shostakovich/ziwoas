<div class="sw-head" id="sw_head_<%= row.plug.id %>">
  <div class="sw-info">
    <span class="sw-name"><%= row.plug.name %></span>
    <div class="sw-sub"><%= switch_status_line(row) %></div>
    <div class="sw-error" id="sw_error_<%= row.plug.id %>"></div>
  </div>
  <div class="sw-knob-col">
    <%= button_to "", plug_switch_path(plug_id: row.plug.id, state: row.on? ? "off" : "on"),
                  class: "sw-knob#{' off' if row.offline? || !row.on?}",
                  disabled: row.offline?,
                  form_class: "sw-inline-form sw-knob-form",
                  aria: { label: "#{row.plug.name} #{row.on? ? 'ausschalten' : 'einschalten'}" } %>
    <% on = row.on? && !row.offline? %>
    <span class="sw-watt-chip<%= " hidden" unless on %>" data-switches-watt-chip="<%= row.plug.id %>">
      <span class="sw-bolt" aria-hidden="true">⚡</span>
      <span class="sw-watt" data-switches-watt="<%= row.plug.id %>"><%= "#{row.watt&.round || 0} W" %></span>
    </span>
  </div>
</div>
