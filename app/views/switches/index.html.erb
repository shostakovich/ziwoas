<% content_for :title, "Schalten" %>
<% content_for :body_class, "page-switches" %>
<h1>Schalten</h1>

<div data-controller="switches">
  <% if @rows.empty? %>
    <section class="sw-card empty-state">
      <h2>Keine schaltbaren Steckdosen</h2>
      <p class="sw-empty">Markiere Verbraucher in <code>ziwoas.yml</code> mit <code>switchable: true</code>.</p>
    </section>
  <% end %>

  <% @rows.each do |row| %>
    <%= render "switches/plug_card", row: row %>
  <% end %>

  <% if @orphaned_windows.any? %>
    <h2 class="section-label">Verwaiste Zeitfenster</h2>
    <% @orphaned_windows.each do |window| %>
      <div class="sw-card sw-orphan" id="orphan_window_<%= window.id %>">
        <span class="sw-pill paused"><%= window.plug_id %> · <%= window_label(window) %></span>
        <%= button_to "🗑", switch_window_path(plug_id: window.plug_id, id: window.id),
                      method: :delete, class: "sw-icon-btn", form_class: "sw-inline-form",
                      form: { data: { turbo_confirm: "Verwaistes Zeitfenster wirklich löschen?" } },
                      "aria-label": "Zeitfenster löschen" %>
      </div>
    <% end %>
  <% end %>
</div>
