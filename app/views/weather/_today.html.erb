<%= turbo_frame_tag "weather_today" do %>
  <% if today_weather.any? %>
    <div class="section-label">Heute</div>
    <section class="weather-hour-row" aria-label="Heute">
      <% today_weather.each do |record| %>
        <%= render "weather/hour_card", record: record %>
      <% end %>
    </section>
  <% end %>
<% end %>
