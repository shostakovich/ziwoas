<%
  precip_mm = record.precipitation if record.precipitation && record.precipitation.positive?
  precip_prob = record.precipitation_probability if record.precipitation_probability && record.precipitation_probability >= 30
  wind = record.wind_speed if record.wind_speed && record.wind_speed >= 20
  has_extras = precip_mm || precip_prob || wind
%>
<article class="weather-hour-card">
  <div class="weather-hour-time"><%= record.timestamp.strftime("%H:%M") %></div>
  <%= image_tag record.asset_name, class: "weather-hour-icon", width: 42, height: 42, loading: "lazy", alt: weather_icon_label(record.icon) %>
  <strong><%= number_with_precision(record.temperature, precision: 0, delimiter: ".", separator: ",") %>°</strong>
  <% if record.daytime != "night" %>
    <div class="weather-hour-solar">
      <%= image_tag "weather_clear_day.webp", class: "weather-inline-icon", alt: "" %>
      <% if record.solar_w_per_m2 %>
        <%= number_with_precision(record.solar_w_per_m2, precision: 0, delimiter: ".", separator: ",") %> W/m²
      <% else %>
        — W/m²
      <% end %>
    </div>
  <% end %>
  <% if has_extras %>
    <div class="weather-hour-extras">
      <% parts = [] %>
      <% parts << "💨 #{number_with_precision(wind, precision: 0, delimiter: '.', separator: ',')} km/h" if wind %>
      <% parts << "🌧 #{number_with_precision(precip_mm, precision: 1, delimiter: '.', separator: ',')} mm" if precip_mm %>
      <% parts << "💧 #{precip_prob}%" if precip_prob %>
      <%= parts.join(" · ") %>
    </div>
  <% end %>
</article>
