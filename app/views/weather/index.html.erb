<% content_for :title, "Wetter" %>
<% content_for :body_class, "page-weather" %>

<%= turbo_stream_from "weather" %>

<div class="weather-page">
  <%= render "empty", current_weather: @current_weather, today_weather: @today_weather, future_weather: @future_weather %>
  <%= render "current", current_weather: @current_weather, outdoor_sensor_reading: @outdoor_sensor_reading %>
  <%= render "today", today_weather: @today_weather %>
  <%= render "forecast", future_weather: @future_weather %>
</div>
