<% target = ->(name) { "data-#{target_prefix}-target=\"#{name}\"".html_safe } %>
<svg viewBox="0 0 400 320" style="width:100%;height:auto;display:block">
  <defs>
    <clipPath id="ef-clip">
      <path fill-rule="evenodd" d="M 0,0 H 400 V 320 H 0 Z M 200,40 A 40,40 0 1,0 200,120 A 40,40 0 1,0 200,40 Z M 58,130 A 40,40 0 1,0 58,210 A 40,40 0 1,0 58,130 Z M 342,130 A 40,40 0 1,0 342,210 A 40,40 0 1,0 342,130 Z M 200,220 A 40,40 0 1,0 200,300 A 40,40 0 1,0 200,220 Z"/>
    </clipPath>
  </defs>

  <path <%= target.call("efLineSolarHome") %> d="M 200,122 C 205,150 250,166 306,170" fill="none" stroke="#f59f00" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  <path <%= target.call("efLineSolarGrid") %> d="M 200,122 C 195,150 150,166 94,170" fill="none" stroke="#8b5cf6" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  <path <%= target.call("efLineSolarBattery") %> d="M 200,122 L 200,218" fill="none" stroke="#ec4899" stroke-width="3" stroke-linecap="round"/>
  <path <%= target.call("efLineGridHome") %> d="M 94,170 L 306,170" fill="none" stroke="#3b82f6" stroke-width="3" stroke-linecap="round"/>
  <path <%= target.call("efLineGridBattery") %> d="M 94,170 C 150,174 195,190 200,218" fill="none" stroke="#94a3b8" stroke-width="3" stroke-linecap="round"/>
  <path <%= target.call("efLineBatteryHome") %> d="M 200,218 C 205,190 250,174 306,170" fill="none" stroke="#14b8a6" stroke-width="3" stroke-linecap="round"/>

  <g <%= target.call("efDotsSolarHome") %> clip-path="url(#ef-clip)"></g>
  <g <%= target.call("efDotsSolarGrid") %> clip-path="url(#ef-clip)"></g>
  <g <%= target.call("efDotsSolarBattery") %> clip-path="url(#ef-clip)"></g>
  <g <%= target.call("efDotsGridHome") %> clip-path="url(#ef-clip)"></g>
  <g <%= target.call("efDotsGridBattery") %> clip-path="url(#ef-clip)"></g>
  <g <%= target.call("efDotsBatteryHome") %> clip-path="url(#ef-clip)"></g>

  <circle cx="200" cy="80" r="40" fill="white" stroke="#f59f00" stroke-width="2.5"/>
  <image href="<%= asset_path pv_asset %>" x="184" y="55" width="32" height="32"/>
  <text <%= target.call("efPvW") %> x="200" y="102" text-anchor="middle" font-size="12" font-weight="600" fill="#7c5e00">— W</text>
  <text x="200" y="22" text-anchor="middle" font-size="11" fill="#6c757d">PV-Anlage</text>

  <circle cx="58" cy="170" r="40" fill="white" stroke="#3b82f6" stroke-width="2.5"/>
  <image href="<%= asset_path "icon_netz.webp" %>" x="42" y="145" width="32" height="32"/>
  <text <%= target.call("efGridW") %> x="58" y="192" text-anchor="middle" font-size="12" font-weight="600" fill="#1d4ed8">— W</text>
  <text x="58" y="224" text-anchor="middle" font-size="11" fill="#6c757d">Stromnetz</text>

  <circle cx="342" cy="170" r="40" fill="white" stroke="none"/>
  <circle cx="342" cy="170" r="40" fill="none" stroke="#e9ecef" stroke-width="2.5"/>
  <g <%= target.call("efConsumerRing") %> transform="rotate(-90 342 170)" fill="none" stroke-linecap="butt"></g>
  <image href="<%= asset_path "icon_haus.webp" %>" x="326" y="145" width="32" height="32"/>
  <text <%= target.call("efConsumerW") %> x="342" y="192" text-anchor="middle" font-size="12" font-weight="600" fill="#065f46">— W</text>
  <text x="342" y="224" text-anchor="middle" font-size="11" fill="#6c757d">Verbraucher</text>

  <circle cx="200" cy="260" r="40" fill="white" stroke="#22c55e" stroke-width="2.5"/>
  <image href="<%= asset_path battery_asset %>" x="184" y="235" width="32" height="32" preserveAspectRatio="xMidYMid meet"/>
  <text <%= target.call("efBatteryW") %> x="200" y="282" text-anchor="middle" font-size="11" font-weight="600" fill="#15803d">— W</text>
  <text <%= target.call("efBatterySoc") %> x="200" y="291" text-anchor="middle" font-size="9" font-weight="600" fill="#6c757d">— %</text>
  <text x="200" y="315" text-anchor="middle" font-size="11" fill="#6c757d">Batterie</text>
</svg>
