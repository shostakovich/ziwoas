<% content_for :title, "Dashboard" %>
<% content_for :body_class, "page-dashboard" %>
<h1>Dashboard</h1>

<div data-controller="dashboard">
  <!-- Hero: PV live | Batterie-Ladestand (zwei gleichwertige Hälften) -->
  <div class="hero">
    <div class="hero-half">
      <%= image_tag @dashboard_weather_asset, class: "hero-icon", alt: @dashboard_weather_alt %>
      <div class="hero-value" data-dashboard-target="heroValue">— <span class="hero-unit">W</span></div>
    </div>
    <div class="hero-half" data-dashboard-target="heroBattery">
      <%= image_tag "icon_batterie.webp", class: "hero-icon hero-icon-battery", alt: "Batterie" %>
      <div class="hero-value" data-dashboard-target="heroBatterySoc">— <span class="hero-unit">%</span></div>
    </div>
  </div>

  <!-- Tiles: today's numbers -->
  <div class="tiles">
    <div class="tile">
      <div class="tile-label">Erzeugt heute</div>
      <div class="tile-value" data-dashboard-target="tileProduced">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Verbraucht heute</div>
      <div class="tile-value" data-dashboard-target="tileConsumed">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Gespart heute</div>
      <div class="tile-value" data-dashboard-target="tileSavings">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Bilanz heute</div>
      <div class="tile-value" data-dashboard-target="tileNettoday">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Verbrauch jetzt</div>
      <div class="tile-value" data-dashboard-target="tileConsumption">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Bilanz jetzt</div>
      <div class="tile-value" data-dashboard-target="tileNetbalance">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Autarkie heute</div>
      <div class="tile-value" data-dashboard-target="tileAutarky">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Eigenverbrauch</div>
      <div class="tile-value" data-dashboard-target="tileSelfConsumption">—</div>
    </div>
  </div>

  <!-- Energiefluss -->
  <h2 class="section-label">Energiefluss</h2>
  <div class="chart-card energy-flow-card">
    <svg viewBox="0 0 400 320" style="width:100%;height:auto;display:block">
      <defs>
        <clipPath id="ef-clip">
          <path fill-rule="evenodd" d="M 0,0 H 400 V 320 H 0 Z M 200,40 A 40,40 0 1,0 200,120 A 40,40 0 1,0 200,40 Z M 58,130 A 40,40 0 1,0 58,210 A 40,40 0 1,0 58,130 Z M 342,130 A 40,40 0 1,0 342,210 A 40,40 0 1,0 342,130 Z M 200,220 A 40,40 0 1,0 200,300 A 40,40 0 1,0 200,220 Z"/>
        </clipPath>
      </defs>

      <path data-dashboard-target="efLineSolarHome" d="M 200,122 C 205,150 250,166 306,170" fill="none" stroke="#f59f00" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      <path data-dashboard-target="efLineSolarGrid" d="M 200,122 C 195,150 150,166 94,170" fill="none" stroke="#8b5cf6" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      <path data-dashboard-target="efLineSolarBattery" d="M 200,122 L 200,218" fill="none" stroke="#ec4899" stroke-width="3" stroke-linecap="round"/>
      <path data-dashboard-target="efLineGridHome" d="M 94,170 L 306,170" fill="none" stroke="#3b82f6" stroke-width="3" stroke-linecap="round"/>
      <path data-dashboard-target="efLineGridBattery" d="M 94,170 C 150,174 195,190 200,218" fill="none" stroke="#94a3b8" stroke-width="3" stroke-linecap="round"/>
      <path data-dashboard-target="efLineBatteryHome" d="M 200,218 C 205,190 250,174 306,170" fill="none" stroke="#14b8a6" stroke-width="3" stroke-linecap="round"/>

      <g data-dashboard-target="efDotsSolarHome" clip-path="url(#ef-clip)"></g>
      <g data-dashboard-target="efDotsSolarGrid" clip-path="url(#ef-clip)"></g>
      <g data-dashboard-target="efDotsSolarBattery" clip-path="url(#ef-clip)"></g>
      <g data-dashboard-target="efDotsGridHome" clip-path="url(#ef-clip)"></g>
      <g data-dashboard-target="efDotsGridBattery" clip-path="url(#ef-clip)"></g>
      <g data-dashboard-target="efDotsBatteryHome" clip-path="url(#ef-clip)"></g>

      <circle cx="200" cy="80" r="40" fill="white" stroke="#f59f00" stroke-width="2.5"/>
      <image href="<%= asset_path @dashboard_weather_asset %>" x="184" y="55" width="32" height="32"/>
      <text data-dashboard-target="efPvW" x="200" y="102" text-anchor="middle" font-size="12" font-weight="600" fill="#7c5e00">— W</text>
      <text x="200" y="22" text-anchor="middle" font-size="11" fill="#6c757d">PV-Anlage</text>

      <circle cx="58" cy="170" r="40" fill="white" stroke="#3b82f6" stroke-width="2.5"/>
      <image href="<%= asset_path "icon_netz.webp" %>" x="42" y="145" width="32" height="32"/>
      <text data-dashboard-target="efGridW" x="58" y="192" text-anchor="middle" font-size="12" font-weight="600" fill="#1d4ed8">— W</text>
      <text x="58" y="224" text-anchor="middle" font-size="11" fill="#6c757d">Stromnetz</text>

      <circle cx="342" cy="170" r="40" fill="white" stroke="none"/>
      <circle cx="342" cy="170" r="40" fill="none" stroke="#e9ecef" stroke-width="2.5"/>
      <g data-dashboard-target="efConsumerRing" transform="rotate(-90 342 170)" fill="none" stroke-linecap="butt"></g>
      <image href="<%= asset_path "icon_haus.webp" %>" x="326" y="145" width="32" height="32"/>
      <text data-dashboard-target="efConsumerW" x="342" y="192" text-anchor="middle" font-size="12" font-weight="600" fill="#065f46">— W</text>
      <text x="342" y="224" text-anchor="middle" font-size="11" fill="#6c757d">Verbraucher</text>

      <circle cx="200" cy="260" r="40" fill="white" stroke="#22c55e" stroke-width="2.5"/>
      <image href="<%= asset_path "icon_batterie.webp" %>" x="184" y="235" width="32" height="32" preserveAspectRatio="xMidYMid meet"/>
      <text data-dashboard-target="efBatteryW" x="200" y="282" text-anchor="middle" font-size="11" font-weight="600" fill="#15803d">— W</text>
      <text data-dashboard-target="efBatterySoc" x="200" y="291" text-anchor="middle" font-size="9" font-weight="600" fill="#6c757d">— %</text>
      <text x="200" y="315" text-anchor="middle" font-size="11" fill="#6c757d">Batterie</text>
    </svg>
  </div>

  <!-- Plug chips -->
  <h2 class="section-label">Steckdosen</h2>
  <div class="plugs" data-dashboard-target="plugList">—</div>

  <!-- Today + Energy charts -->
  <div data-controller="today-chart">
    <h2 class="section-label">Gesamtenergie — Letzte 24 h</h2>
    <div class="chart-card">
      <div class="chart-frame">
        <canvas data-today-chart-target="energyCanvas"></canvas>
      </div>
    </div>

    <h2 class="section-label">Leistung — Letzte 24 h</h2>
    <div class="chart-card">
      <div class="chart-frame">
        <canvas data-today-chart-target="powerCanvas"></canvas>
      </div>
    </div>
  </div>

  <!-- History chart -->
  <div data-controller="history-chart">
    <h2 class="section-label">Ertrag — Letzte 14 Tage</h2>
    <div class="chart-card">
      <div class="chart-frame">
        <canvas data-history-chart-target="canvas"></canvas>
      </div>
    </div>
  </div>
</div>
