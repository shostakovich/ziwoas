<% content_for :title, "Dashboard" %>
<h1>Dashboard</h1>

<div data-controller="dashboard">
  <!-- Hero: PV live -->
  <div class="hero">
    <%= image_tag @dashboard_weather_asset, class: "hero-icon", alt: @dashboard_weather_alt %>
    <div class="hero-value" data-dashboard-target="heroValue">— <span class="hero-unit">W</span></div>
  </div>

  <!-- Tiles: today's numbers -->
  <div class="tiles">
    <div class="tile">
      <div class="tile-label">Erzeugt heute</div>
      <div class="tile-value" data-dashboard-target="tileProduced">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Verbraucht heute</div>
      <div class="tile-value" data-dashboard-target="tileConsumed">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Gespart heute</div>
      <div class="tile-value" data-dashboard-target="tileSavings">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Bilanz heute</div>
      <div class="tile-value" data-dashboard-target="tileNettoday">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Verbrauch jetzt</div>
      <div class="tile-value" data-dashboard-target="tileConsumption">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Bilanz jetzt</div>
      <div class="tile-value" data-dashboard-target="tileNetbalance">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Autarkie heute</div>
      <div class="tile-value" data-dashboard-target="tileAutarky">—</div>
    </div>
    <div class="tile">
      <div class="tile-label">Eigenverbrauch</div>
      <div class="tile-value" data-dashboard-target="tileSelfConsumption">—</div>
    </div>
  </div>

  <!-- Energiefluss -->
  <h2 class="section-label">Energiefluss</h2>
  <div class="chart-card" style="padding:12px 8px">
    <svg viewBox="0 0 400 244" style="width:100%;height:auto;display:block">
      <defs>
        <!-- Clip region: full SVG minus the three node circles (evenodd punches out the circles) -->
        <clipPath id="ef-clip">
          <path fill-rule="evenodd" d="M 0,0 H 400 V 244 H 0 Z M 200,40 A 40,40 0 1,0 200,120 A 40,40 0 1,0 200,40 Z M 58,135 A 40,40 0 1,0 58,215 A 40,40 0 1,0 58,135 Z M 342,131 A 44,44 0 1,0 342,219 A 44,44 0 1,0 342,131 Z"/>
        </clipPath>
      </defs>
      <line data-dashboard-target="efLineV"   x1="200" y1="120" x2="200" y2="175" stroke="#dee2e6" stroke-width="3" stroke-linecap="round"/>
      <line data-dashboard-target="efLineHl"  x1="98"  y1="175" x2="200" y2="175" stroke="#dee2e6" stroke-width="3" stroke-linecap="round"/>
      <line data-dashboard-target="efLineHr"  x1="200" y1="175" x2="298" y2="175" stroke="#dee2e6" stroke-width="3" stroke-linecap="round"/>
      <g data-dashboard-target="efDotsPvHome"   clip-path="url(#ef-clip)"></g>
      <g data-dashboard-target="efDotsGridHome" clip-path="url(#ef-clip)"></g>
      <g data-dashboard-target="efDotsPvGrid"   clip-path="url(#ef-clip)"></g>
      <circle cx="200" cy="80"  r="40" fill="white" stroke="#f59f00" stroke-width="2.5"/>
      <image href="<%= asset_path @dashboard_weather_asset %>" x="184" y="55" width="32" height="32"/>
      <text data-dashboard-target="efPvW" x="200" y="102"  text-anchor="middle" font-size="12" font-weight="600" fill="#7c5e00">— W</text>
      <text x="200" y="22"  text-anchor="middle" font-size="11" fill="#6c757d">PV-Anlage</text>
      <circle cx="58"  cy="175" r="40" fill="white" stroke="#3b82f6" stroke-width="2.5"/>
      <image href="<%= asset_path 'icon_netz.webp' %>" x="42" y="150" width="32" height="32"/>
      <text data-dashboard-target="efGridW" x="58"  y="197" text-anchor="middle" font-size="12" font-weight="600" fill="#1d4ed8">— W</text>
      <text x="58"  y="229" text-anchor="middle" font-size="11" fill="#6c757d">Stromnetz</text>
      <!-- Consumer breakdown ring -->
      <circle cx="342" cy="175" r="44" fill="none" stroke="#e9ecef" stroke-width="2.5"/>
      <circle data-dashboard-target="efRingPv"   cx="342" cy="175" r="44" fill="none" stroke="#f59f00" stroke-width="2.5" stroke-dasharray="0 276.5" transform="rotate(-90,342,175)"/>
      <circle data-dashboard-target="efRingGrid" cx="342" cy="175" r="44" fill="none" stroke="#3b82f6" stroke-width="2.5" stroke-dasharray="0 276.5" transform="rotate(-90,342,175)"/>
      <circle cx="342" cy="175" r="40" fill="white" stroke="none"/>
      <image href="<%= asset_path 'icon_haus.webp' %>" x="326" y="150" width="32" height="32"/>
      <text data-dashboard-target="efConsumerW" x="342" y="197" text-anchor="middle" font-size="12" font-weight="600" fill="#065f46">— W</text>
      <text x="342" y="229" text-anchor="middle" font-size="11" fill="#6c757d">Verbraucher</text>
    </svg>
  </div>

  <!-- Plug chips -->
  <h2 class="section-label">Steckdosen</h2>
  <div class="plugs" data-dashboard-target="plugList">—</div>

  <!-- Today + Energy charts -->
  <div data-controller="today-chart">
    <h2 class="section-label">Gesamtenergie — Letzte 24 h</h2>
    <div class="chart-card">
      <div class="chart-frame">
        <canvas data-today-chart-target="energyCanvas"></canvas>
      </div>
    </div>

    <h2 class="section-label">Leistung — Letzte 24 h</h2>
    <div class="chart-card">
      <div class="chart-frame">
        <canvas data-today-chart-target="powerCanvas"></canvas>
      </div>
    </div>
  </div>

  <!-- History chart -->
  <div data-controller="history-chart">
    <h2 class="section-label">Ertrag — Letzte 14 Tage</h2>
    <div class="chart-card">
      <div class="chart-frame">
        <canvas data-history-chart-target="canvas"></canvas>
      </div>
    </div>
  </div>
</div>
